// File: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Parwa {
  id          Int      @id @default(autoincrement())
  book        String                                
  sub_parva   String?                                
  section     String?                                
  judul       String?                                
  url         String?                                
  isi         String   @db.LongText                  
  createdAt   DateTime @default(now())              
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}
